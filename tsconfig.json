{
    "compilerOptions": {
        "allowJs": true,
        "esModuleInterop": true,
        "incremental": true,
        "isolatedModules": true,
        "lib": ["dom", "dom.iterable", "esnext"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@backend/*": ["./backend/src/*"],
            "@frontend/*": ["./frontend/src/*"]
        },
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "esnext",
        "types": ["worker-configuration.d.ts"]
    },
    "exclude": ["node_modules"],
    "include": ["**/*.ts", "**/*.tsx", "**/*.mts"]
}
