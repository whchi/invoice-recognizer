# Required secrets — set via `wrangler secret put <NAME>`
# Do NOT commit real values to the repository.

# Google Gemini API key for invoice parsing (Vision API)
GEMINI_API_KEY=your-gemini-api-key-here

# R2 S3-compatible API credentials (for presigned URLs via aws4fetch)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=
# D1 database credentials
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=
# only "online" will enable remote access
APP_MODE=local
# better auth
BETTER_AUTH_URL=http://localhost:8787
BETTER_AUTH_SECRET=your-better-auth-secret
